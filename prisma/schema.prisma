// Deskly — Mercator desk booking POC
// SQLite + Prisma. Maps the four core entities (Premise, Bookable, Booking,
// Booker) plus Zone (map geometry) and AppSettings (auto-release config).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Premise {
  id            String     @id @default(cuid())
  name          String
  address       String
  // mapView = the canvas the floor plan is drawn on
  mapWidth      Int        @default(1200)
  mapHeight     Int        @default(800)
  backgroundUrl String?
  // World-space placement of the background image so a floor-plan scan can be
  // scaled/positioned to line up with the drawn layout (editable in the admin).
  bgX           Float      @default(0)
  bgY           Float      @default(0)
  bgWidth       Float      @default(1200)
  bgHeight      Float      @default(800)
  // Global wall appearance, applied to every WALL fixture in the plan.
  wallColor     String     @default("#334155")
  wallOpacity   Float      @default(1)
  zones         Zone[]
  bookables     Bookable[]
  fixtures      Fixture[]
  createdAt     DateTime   @default(now())
}

// Non-bookable layout elements: walls, doors, windows, toilets, fire exits,
// stairs, plants, etc. Pure map decoration — drawn as a positioned, sizable,
// rotatable box. `type` selects the visual from FIXTURE_META.
model Fixture {
  id        String  @id @default(cuid())
  premise   Premise @relation(fields: [premiseId], references: [id], onDelete: Cascade)
  premiseId String
  type      String  @default("WALL")
  label     String  @default("")
  x         Float   @default(120)
  y         Float   @default(120)
  width     Float   @default(160)
  height    Float   @default(16)
  rotation  Float   @default(0)
}

model Zone {
  id        String     @id @default(cuid())
  premise   Premise    @relation(fields: [premiseId], references: [id], onDelete: Cascade)
  premiseId String
  name      String
  type      String     @default("FOCUS") // QUIET | COLLAB | STANDING | FOCUS | SOCIAL
  color     String     @default("#14b8a6")
  // Bounding box — kept in sync with `points` for legacy/query use.
  x         Float      @default(40)
  y         Float      @default(40)
  width     Float      @default(280)
  height    Float      @default(220)
  // JSON-encoded polygon outline, e.g. [{"x":40,"y":40},...]. Empty = use bbox.
  points    String     @default("[]")
  bookables Bookable[]
}

model Bookable {
  id              String    @id @default(cuid())
  premise         Premise   @relation(fields: [premiseId], references: [id], onDelete: Cascade)
  premiseId       String
  zone            Zone?     @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  zoneId          String?
  name            String
  type            String    @default("DESK") // DESK | ROOM
  // Multi-person desks/tables: a Bookable with seats > 1 exposes that many
  // individually-bookable seats laid out by `shape` around its width/height box.
  seats           Int       @default(1)
  shape           String    @default("RECT") // RECT | ROUND (seat layout)
  width           Float     @default(66)
  height          Float     @default(48)
  seatSize        Float     @default(18) // seat-marker diameter (adjustable)
  seatGap         Float     @default(5) // gap between a seat marker and the table edge
  seatShape       String    @default("ROUND") // chair marker shape: ROUND | RECT
  seatSide        String    @default("BOTTOM") // single-desk chair edge: TOP | RIGHT | BOTTOM | LEFT
  fontSize        Float     @default(11) // desk/table name label size (px)
  endSeats        Boolean   @default(false) // RECT only: seat each short end too
  isAvailable     Boolean   @default(true)
  // JSON-encoded availability windows, e.g. [{"day":"MON","from":"09:00","to":"18:00"}]
  timesAvailable  String    @default("[]")
  // contentDescriptionTags — JSON string[] e.g. ["monitor","standing","window"]
  tags            String    @default("[]")
  textDescription String    @default("")
  x               Float     @default(100)
  y               Float     @default(100)
  bookings        Booking[] @relation("BookingBookables")
}

model Booker {
  id       String    @id @default(cuid())
  email    String    @unique
  name     String
  team     String
  role     String    @default("USER") // USER | ADMIN
  bookings Booking[]
}

model Booking {
  id              String     @id @default(cuid())
  booker          Booker     @relation(fields: [bookerId], references: [id], onDelete: Cascade)
  bookerId        String
  bookables       Bookable[] @relation("BookingBookables")
  date            String     // ISO date "2026-06-18" (the day booked)
  // Which seat of the bookable this booking holds (0 for single-seat desks/rooms).
  seatIndex       Int        @default(0)
  startTime       String     @default("09:00")
  endTime         String     @default("17:00")
  repeat          String     @default("NONE") // NONE | DAILY | WEEKLY
  bookingTitle    String     @default("")
  bookingGuidance String     @default("")
  status          String     @default("RESERVED") // RESERVED | CHECKED_IN | CHECKED_OUT | RELEASED
  checkInAt       DateTime?
  checkOutAt      DateTime?
  createdAt       DateTime   @default(now())
}

model AppSettings {
  id                 String @id @default("singleton")
  autoReleaseMinutes Int    @default(30)
  // Floor-plan legend colours (desk status). Hex strings.
  freeColor          String @default("#22c55e")
  takenColor         String @default("#f59e0b")
  yoursColor         String @default("#3b82f6")
  unavailableColor   String @default("#cbd5d8")
}
